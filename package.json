{
  "name": "prompt-diary",
  "private": true,
  "workspaces": [
    "extension",
    "web",
    "shared"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "build": "bun run --filter '*' build",
    "db:up": "docker compose up -d",
    "db:migrate": "cd web && bun run db:migrate",
    "dev:web": "cd web && bun run dev",
    "dev:extension": "cd extension && bun run dev"
  }
}
