# copy to web/.env.local for development
# local docker: postgres://promptdiary:promptdiary@localhost:5432/promptdiary
# prod: your Neon connection string
DATABASE_URL=postgres://promptdiary:promptdiary@localhost:5432/promptdiary

# Better Auth
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com -> credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
