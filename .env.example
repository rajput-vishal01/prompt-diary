# copy to .env at the repo root — the single env file for everything
# local docker: postgres://promptdiary:promptdiary@localhost:5433/promptdiary
# prod: your Neon connection string
DATABASE_URL=postgres://promptdiary:promptdiary@localhost:5433/promptdiary

# Better Auth
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com -> credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Verification emails via Gmail SMTP (myaccount.google.com -> Security ->
# 2-Step Verification -> App passwords). Leave empty in dev to log links instead.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Image uploads via Cloudinary (cloudinary.com -> Dashboard -> API keys).
# Leave empty to hide upload buttons entirely.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Chrome extension ids allowed to call the API with credentials, comma-separated.
# Leave empty in dev (any unpacked extension id works). SET THIS IN PROD to your
# published Web Store id so other extensions can't ride users' sessions.
EXTENSION_IDS=

# Upstash Redis (optional — enables multi-instance rate limiting in prod;
# without these the API falls back to in-memory limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Polar billing (optional — without POLAR_ACCESS_TOKEN everything is free
# and no billing UI is shown; use the sandbox token + POLAR_SERVER=sandbox
# while testing)
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
